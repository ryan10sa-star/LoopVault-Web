# LoopVault environment variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.

# Supabase project credentials (required for authentication)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Set to 'true' to bypass the subscription gate during development/testing.
# NOTE (Ryan): Set this in .env.local while testing before you have a live LemonSqueezy product.
VITE_BYPASS_SUBSCRIPTION=false

# LemonSqueezy checkout URL — replace with your real product checkout link.
# NOTE (Ryan): Create the product in LemonSqueezy dashboard, then paste the checkout URL here.
VITE_LEMONSQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/your-product-id
